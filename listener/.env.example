# Telegram API credentials from https://my.telegram.org (log in, go to "API development tools")
TG_API_ID=123456
TG_API_HASH=0123456789abcdef0123456789abcdef

# Path where Telethon stores its session file. Keep it out of git.
# On Railway/Fly you can set this to /data/vn_listener so it lives on a persistent volume.
TG_SESSION=./vn_listener.session

# The public Telegram channel to read, WITHOUT the leading @.
# Example: if the channel is https://t.me/russians_in_vietnam -> TG_CHANNEL=russians_in_vietnam
TG_CHANNEL=russians_in_vietnam

# Supabase credentials.
# URL: Project Settings -> API -> Project URL.
# Service key: Project Settings -> API -> "service_role" (secret, keep server-side only).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...service-role-key...

# OpenAI API key for classification + translation.
OPENAI_API_KEY=sk-...

# Model used for classify+translate. gpt-4o-mini is cheap and good enough.
OPENAI_MODEL=gpt-4o-mini

# How many days of history to import during backfill (used by backfill.py only).
BACKFILL_DAYS=365

# Public Supabase Storage bucket used for message photos. Create it in the
# Supabase dashboard: Storage -> New bucket -> name "chat-media", public = ON.
MEDIA_BUCKET=chat-media
